from abc import ABC, abstractmethod
from typing import List

class Notifier(ABC):
    @abstractmethod
    def send(self, recipient: str, text: str) -> None:
        pass

class EmailClient(Notifier):
    def send(self, recipient: str, text: str) -> None:
        print(f"[EMAIL to={recipient}] {text}")

class SmsClient(Notifier):
    def send(self, recipient: str, text: str) -> None:
        print(f"[SMS to={recipient}] {text}")

class PushNotifier(Notifier):
    def send(self, recipient: str, text: str) -> None:
        print(f"[PUSH to={recipient}] {text}")

class FakeNotifier(Notifier):
    def __init__(self):
        self.sent_messages = []

    def send(self, recipient: str, text: str) -> None:
        self.sent_messages.append((recipient, text))

    def get_sent_messages(self) -> List[tuple]:
        return self.sent_messages

class NotificationService:
    def __init__(self, notifiers: List[Notifier]):
        self._notifiers = notifiers

    def notify(self, recipients: dict, text: str) -> None:
        for method, recipient in recipients.items():
            for notifier in self._notifiers:
                notifier.send(recipient, text)